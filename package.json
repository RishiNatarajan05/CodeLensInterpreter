{
  "name": "codelens-interpreter",
  "displayName": "CodeLens Interpreter",
  "description": "Explain or translate any highlighted code using Claude AI with repo-aware context",
  "version": "0.1.0",
  "publisher": "codelens-interpreter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/codelens-interpreter"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Programming Languages"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codelens-interpreter.explain",
        "title": "CodeLens: Explain This Code"
      },
      {
        "command": "codelens-interpreter.translate",
        "title": "CodeLens: Translate This Code"
      },
      {
        "command": "codelens-interpreter.setApiKey",
        "title": "CodeLens: Set Anthropic API Key"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codelens-interpreter.explain",
          "when": "editorHasSelection",
          "group": "codelens-interpreter@1"
        },
        {
          "command": "codelens-interpreter.translate",
          "when": "editorHasSelection",
          "group": "codelens-interpreter@2"
        }
      ]
    },
    "configuration": {
      "title": "CodeLens Interpreter",
      "properties": {
        "codelensInterpreter.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model to use for code explanation and translation"
        },
        "codelensInterpreter.maxContextTokens": {
          "type": "number",
          "default": 6000,
          "description": "Maximum number of tokens for repo context"
        },
        "codelensInterpreter.maxResponseTokens": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of tokens in the response"
        },
        "codelensInterpreter.translationLanguages": {
          "type": "array",
          "default": ["Python", "Java", "Go", "Rust", "TypeScript", "C#"],
          "description": "Languages shown in the quick-switch toolbar and translate picker"
        }
      }
    },
    "keybindings": [
      {
        "command": "codelens-interpreter.explain",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "codelens-interpreter.translate",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "web-tree-sitter": "^0.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
